generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CLIENT
}

enum NodeStatus {
  locked
  active
  complete
  flagged
  cascading
}

enum FlagType {
  needs_review
  cascading
}

enum DisplayLayer {
  CHAPTER
  FULL
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  name          String?
  passwordHash  String
  role          Role             @default(CLIENT)
  active        Boolean          @default(true)
  deactivatedAt DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  engagements   EngagementUser[]
}

model Engagement {
  id             String                 @id @default(cuid())
  clientName     String
  lifecycleStage String                 @default("Traction")
  clientLogoUrl  String?
  internalNotes  String?                @db.Text
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  nodes          Node[]
  users          EngagementUser[]
  nodeConfigs    EngagementNodeConfig[]
  assets         EngagementAsset[]
}

model EngagementUser {
  id           String     @id @default(cuid())
  userId       String
  engagementId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  engagement   Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@unique([userId, engagementId])
}

model Node {
  id            String           @id @default(cuid())
  engagementId  String
  nodeKey       String
  displayName   String
  sortOrder     Int
  isGate        Boolean          @default(false)
  isConditional Boolean          @default(false)
  status        NodeStatus       @default(locked)
  lockedIn      Boolean          @default(false)
  lockedInAt    DateTime?
  lockedInBy    String?
  engagement    Engagement       @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  // Dependencies: this node depends on...
  dependsOn     NodeDependency[] @relation("dependent")
  // Nodes that depend on this one
  dependedOnBy  NodeDependency[] @relation("dependency")

  versions      NodeVersion[]
  flagsReceived CascadeFlag[]    @relation("flaggedNode")
  flagsCaused   CascadeFlag[]    @relation("sourceNode")
  configs       EngagementNodeConfig[]

  @@unique([engagementId, nodeKey])
}

model NodeDependency {
  id             String @id @default(cuid())
  nodeId         String
  dependsOnNodeId String
  node           Node   @relation("dependent", fields: [nodeId], references: [id], onDelete: Cascade)
  dependsOnNode  Node   @relation("dependency", fields: [dependsOnNodeId], references: [id], onDelete: Cascade)

  @@unique([nodeId, dependsOnNodeId])
}

model NodeVersion {
  id                String        @id @default(cuid())
  nodeId            String
  versionNumber     Int           @default(1)
  execSummary       String?       @db.Text
  documentUrl       String?
  changeType        String?
  changeNote        String?
  isCurrent         Boolean       @default(true)
  isBaseline        Boolean       @default(false)
  cascadeTriggering Boolean       @default(false)
  docxOutOfSync     Boolean       @default(false)
  docxRegeneratedAt DateTime?
  createdAt         DateTime      @default(now())
  node              Node          @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  sections          NodeSection[]
}

model NodeTemplate {
  id            String       @id @default(cuid())
  nodeKey       String
  sectionKey    String
  sectionTitle  String
  sortOrder     Int
  displayLayer  DisplayLayer
  isRequired    Boolean      @default(true)
  isConditional Boolean      @default(false)
  description   String?      @db.Text

  @@unique([nodeKey, sectionKey])
  @@index([nodeKey])
}

model NodeSection {
  id                String       @id @default(cuid())
  nodeVersionId     String
  sectionKey        String
  sectionTitle      String
  content           String       @db.Text
  sortOrder         Int
  displayLayer      DisplayLayer
  isInherited       Boolean      @default(false)
  inheritedFromNode String?
  nodeVersion       NodeVersion  @relation(fields: [nodeVersionId], references: [id], onDelete: Cascade)

  @@unique([nodeVersionId, sectionKey])
  @@index([nodeVersionId])
}

model CascadeFlag {
  id              String   @id @default(cuid())
  flaggedNodeId   String
  sourceNodeId    String
  flagType        FlagType
  sourceChangeDate DateTime @default(now())
  resolved        Boolean  @default(false)
  resolvedAt      DateTime?
  flaggedNode     Node     @relation("flaggedNode", fields: [flaggedNodeId], references: [id], onDelete: Cascade)
  sourceNode      Node     @relation("sourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
}

model EngagementNodeConfig {
  id             String     @id @default(cuid())
  engagementId   String
  nodeId         String
  excluded       Boolean    @default(false)
  sectionToggles Json?
  engagement     Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  node           Node       @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([engagementId, nodeId])
}

model EngagementAsset {
  id           String     @id @default(cuid())
  engagementId String
  filename     String
  url          String
  mimeType     String
  sizeBytes    Int
  uploadedAt   DateTime   @default(now())
  uploadedBy   String
  engagement   Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
}
